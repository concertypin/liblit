{
    "name": "@concertypin/liblit",
    "version": "0.1.0",
    "type": "module",
    "license": "Apache-2.0",
    "author": {
        "name": "concertypin",
        "url": "https://github.com/concertypin"
    },
    "description": "Isomorphic NovelAI Image API client library",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*/index.d.ts",
            "import": "./dist/*/index.js"
        }
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "format": "prettier --write . --cache --list-different",
        "lint:check": "oxlint .",
        "lint": "oxlint . --fix",
        "postinstall": "pnpm exec simple-git-hooks",
        "check": "pnpm run format && pnpm run lint && pnpm run test && git add -u",
        "pre-commit": "pnpm run check",
        "test": "vitest run"
    },
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.6",
        "cross-env": "^10.1.0",
        "globals": "^17.6.0",
        "oxlint": "^1.66.0",
        "oxlint-tsgolint": "^0.23.0",
        "prettier": "^3.8.3",
        "simple-git-hooks": "^2.13.1",
        "typescript": "~6.0.3",
        "vite": "^8.0.13",
        "vite-plugin-dts": "^5.0.1",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "fflate": "^0.8.3",
        "zod": "^4.4.3"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
