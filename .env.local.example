# NovelAI API Key — used as fallback token in NovelAIConfig
# When set, you can omit `token` in `NovelAIConfig`.
# Copy this file to `.env.local` and fill in your key.
NOVELAI_KEY=

# Optional: Custom API base URL (default: https://image.novelai.net)
# NOVELAI_BASE_URL=https://image.novelai.net

# Set to "1" to enable live integration tests (⚠️ burns anlas/credits!)
# NAI_LIVE_TEST=0
